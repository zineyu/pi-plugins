{
	"name": "@zineyu/pi-hashline",
	"version": "0.2.0",
	"description": "Hashline edit tool for pi — line-anchored file edits via content hashes",
	"keywords": [
		"pi-package"
	],
	"license": "MIT",
	"author": "zineyu",
	"repository": {
		"type": "git",
		"url": "https://github.com/zineyu/pi-plugins.git",
		"directory": "packages/pi-hashline"
	},
	"files": [
		"src",
		"README.md",
		"AGENTS.md"
	],
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"pi": {
		"extensions": [
			"./src/hashline.ts"
		]
	},
	"devDependencies": {
		"@earendil-works/pi-coding-agent": "^0.79.3",
		"@types/node": "^25.9.3",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"diff": "^9.0.0"
	}
}
