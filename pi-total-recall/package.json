{
  "name": "pi-total-recall",
  "version": "1.8.0",
  "description": "Complete context stack for pi — persistent memory, session history search, and local knowledge search in one install.",
  "keywords": [
    "pi-package",
    "extension",
    "memory",
    "context",
    "session-search",
    "knowledge-search",
    "semantic-search"
  ],
  "author": "Sam Painter",
  "license": "MIT",
  "scripts": {
    "test": "node --test --import tsx test/**/*.test.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/samfoy/pi-total-recall"
  },
  "dependencies": {
    "@samfp/pi-memory": "^1.3.2",
    "pi-knowledge-search": "^1.3.3",
    "pi-session-search": "^1.4.2"
  },
  "bundledDependencies": [
    "@samfp/pi-memory",
    "pi-session-search",
    "pi-knowledge-search"
  ],
  "pi": {
    "extensions": [
      "node_modules/@samfp/pi-memory/src/index.ts",
      "node_modules/pi-session-search/src/index.ts",
      "node_modules/pi-knowledge-search/src/index.ts"
    ],
    "skills": [
      "node_modules/pi-session-search/skills"
    ]
  },
  "bundleDependencies": [
    "@samfp/pi-memory",
    "pi-session-search",
    "pi-knowledge-search"
  ]
}
